/* ============================================
   全局样式 - 车间管理系统 WMS
   设计系统：现代企业级 UI
   ============================================ */

/* --- 设计 Token --- */
page {
  --primary: #2B6FF2;
  --primary-light: #E8F0FE;
  --primary-dark: #1A56D4;
  --success: #00C853;
  --success-light: #E8F5E9;
  --warning: #FF9500;
  --warning-light: #FFF3E0;
  --danger: #FF3B30;
  --danger-light: #FFEBEE;
  --bg: #F0F2F5;
  --card-bg: #FFFFFF;
  --text-primary: #1A1A2E;
  --text-secondary: #6B7280;
  --text-hint: #9CA3AF;
  --border: #E5E7EB;
  --shadow-sm: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
  --shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 8rpx 40rpx rgba(0, 0, 0, 0.10);
  --radius-sm: 12rpx;
  --radius: 20rpx;
  --radius-lg: 28rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', 'Helvetica Neue', sans-serif;
  background: var(--bg);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* --- 通用容器 --- */
.container {
  padding: 24rpx 28rpx;
  padding-bottom: 120rpx;
}

/* --- 卡片 --- */
.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.card:active {
  transform: scale(0.98);
}

/* --- 按钮系统 --- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  padding: 0 40rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s;
}

.btn-primary {
  background: linear-gradient(135deg, #2B6FF2, #5B8FF9);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(43, 111, 242, 0.30);
}

.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-success {
  background: linear-gradient(135deg, #00C853, #69F0AE);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 200, 83, 0.25);
}

.btn-danger {
  background: #fff;
  color: var(--danger);
  border: 2rpx solid var(--danger-light);
}

.btn-ghost {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary-light);
}

.btn-sm {
  height: 56rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  border-radius: 28rpx;
}

/* --- 表单输入 --- */
.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #F9FAFB;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.input-field:focus {
  border-color: var(--primary);
  background: #fff;
}

/* --- 标签/徽章 --- */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.tag-pending  { background: var(--warning-light); color: #E65100; }
.tag-progress, .tag-in_progress { background: var(--primary-light); color: #1A56D4; }
.tag-completed { background: var(--success-light); color: #1B5E20; }

/* --- 状态指示点 --- */
.dot {
  display: inline-block;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}
.dot-pending  { background: var(--warning); }
.dot-progress { background: var(--primary); }
.dot-completed{ background: var(--success); }

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}
.empty-state .icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-state .text { font-size: 28rpx; color: var(--text-hint); }

/* --- 分割线 --- */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* --- 动画 --- */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.fade-in {
  animation: fadeIn 0.4s ease-out;
}

