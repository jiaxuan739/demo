/* ============================================
   任务管理 - 样式
   ============================================ */

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.toolbar-title { font-size: 32rpx; font-weight: 700; }
.toolbar-count {
  font-size: 24rpx;
  color: var(--text-hint);
  background: #F0F2F5;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
}

/* --- 筛选标签 --- */
.filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}
.filter-tag {
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  background: #fff;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s;
}
.filter-tag.active {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(43,111,242,0.3);
}

/* --- 任务卡片 --- */
.task-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}
.tk-left { width: 8rpx; flex-shrink: 0; }
.tk-status-bar {
  width: 100%;
  height: 100%;
  min-height: 60rpx;
}
.bg-pending     { background: var(--warning); }
.bg-in_progress { background: var(--primary); }
.bg-completed   { background: var(--success); }

.tk-body { flex: 1; padding: 24rpx 24rpx 20rpx; }
.tk-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.tk-title { font-size: 30rpx; font-weight: 700; }
.tk-info { font-size: 24rpx; color: var(--text-secondary); margin-top: 6rpx; }
.tk-meta { display: flex; gap: 24rpx; margin-top: 12rpx; }
.tk-meta-item { font-size: 24rpx; color: var(--text-hint); }
.tk-actions { display: flex; gap: 12rpx; margin-top: 16rpx; }

/* --- 弹窗 --- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
}
.modal-popup {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 36rpx 36rpx 0 0;
  padding: 16rpx 36rpx 60rpx;
  z-index: 101;
  max-height: 85vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}
.modal-popup.show { transform: translateY(0); }
.modal-bar {
  width: 60rpx;
  height: 6rpx;
  background: #D1D5DB;
  border-radius: 3rpx;
  margin: 12rpx auto 24rpx;
}
.modal-title { font-size: 34rpx; font-weight: 700; margin-bottom: 28rpx; }
.modal-actions { display: flex; gap: 16rpx; margin-top: 32rpx; }
.form-row { display: flex; }
.picker-field { display: flex; align-items: center; gap: 12rpx; }

