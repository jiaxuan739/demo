/* ============================================
   我的数据 - 样式
   ============================================ */

/* --- 个人信息卡 --- */
.profile-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}
.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2B6FF2, #5B8FF9);
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
}
.profile-body { flex: 1; min-width: 0; }
.profile-name { font-size: 36rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 12rpx; }
.profile-row {
  display: flex;
  margin-top: 8rpx;
}
.profile-label {
  font-size: 24rpx;
  color: var(--text-hint);
  width: 80rpx;
}
.profile-value {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* --- 统计卡 --- */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}
.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 0;
  text-align: center;
  box-shadow: var(--shadow-sm);
}
.stat-num { font-size: 44rpx; font-weight: 800; color: var(--text-primary); }
.stat-num.highlight { color: var(--primary); }
.stat-num.success   { color: var(--success); }
.stat-label { font-size: 22rpx; color: var(--text-hint); margin-top: 4rpx; }

/* --- 任务卡片 --- */
.task-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}
.tc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.tc-title {
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.tc-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}
.tc-footer {
  display: flex;
  gap: 28rpx;
  margin-bottom: 16rpx;
}
.tc-meta { font-size: 24rpx; color: var(--text-hint); }

/* --- 进度条 --- */
.progress-bar {
  height: 6rpx;
  background: #F0F2F5;
  border-radius: 3rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2B6FF2, #5B8FF9);
  border-radius: 3rpx;
  transition: width 0.6s ease;
}

