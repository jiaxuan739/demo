<!-- 我的数据 - 用户查看自己的信息和任务 -->
<view class="container">

  <!-- 个人信息卡 -->
  <view class="profile-card fade-in">
    <view class="profile-avatar">{{userInfo.name ? userInfo.name[0] : '?'}}</view>
    <view class="profile-body">
      <view class="profile-name">{{userInfo.name}}</view>
      <view class="profile-row">
        <text class="profile-label">学号</text>
        <text class="profile-value">{{userInfo.student_id}}</text>
      </view>
      <view class="profile-row">
        <text class="profile-label">班级</text>
        <text class="profile-value">{{userInfo.class_name || '未设置'}}</text>
      </view>
    </view>
  </view>

  <!-- 统计概览 -->
  <view class="stats-row fade-in" style="animation-delay:0.1s">
    <view class="stat-card">
      <view class="stat-num">{{tasks.length}}</view>
      <view class="stat-label">全部任务</view>
    </view>
    <view class="stat-card">
      <view class="stat-num highlight">{{doingCount}}</view>
      <view class="stat-label">进行中</view>
    </view>
    <view class="stat-card">
      <view class="stat-num success">{{doneCount}}</view>
      <view class="stat-label">已完成</view>
    </view>
  </view>

  <!-- 任务列表 -->
  <view class="section-title">📋 任务列表</view>
  <block wx:for="{{tasks}}" wx:key="id">
    <view class="task-card fade-in" style="animation-delay:{{0.1 + index * 0.05}}s">
      <view class="tc-header">
        <view class="tc-title">
          <view class="dot dot-{{item.status}}"></view>
          {{item.title}}
        </view>
        <view class="tag tag-{{item.status}}">{{statusMap[item.status].label}}</view>
      </view>
      <view class="tc-desc" wx:if="{{item.description}}">{{item.description}}</view>
      <view class="tc-footer">
        <view class="tc-meta">
          <text>📊 产量 {{item.quantity}}</text>
        </view>
        <view class="tc-meta" wx:if="{{item.deadline}}">
          <text>📅 {{item.deadline}}</text>
        </view>
      </view>
      <!-- 进度条 -->
      <view class="progress-bar">
        <view class="progress-fill" style="width:{{item.status === 'completed' ? '100' : item.status === 'in_progress' ? '50' : '10'}}%"></view>
      </view>
    </view>
  </block>

  <view wx:if="{{tasks.length === 0}}" class="empty-state">
    <view class="icon">📭</view>
    <view class="text">暂无任务</view>
  </view>

</view>

